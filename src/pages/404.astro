---
import Layout from "@/layouts/Layout.astro";

const title = "404 - 페이지를 찾을 수 없습니다";
const description = "요청하신 페이지를 찾을 수 없습니다.";
const canonicalURL = new URL("/404", "https://zzinlee.dev").href;
const image = new URL("/og-image.png", "https://zzinlee.dev").href;
---

<Layout title={title} description={description} canonicalURL={canonicalURL} image={image}>
  <div class="flex flex-col items-center justify-center h-screen">
    <span class="text-4xl font-bold white">
      <h1 class="text-4xl font-bold white">404</h1>
    </span>
    <p class="text-2xl text-gray-500">Page not found</p>
  </div>
</Layout>
